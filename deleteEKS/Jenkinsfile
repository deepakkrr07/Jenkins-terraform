pipeline {
    agent any

    environment {
        AWS_REGION = 'ap-southeast-2'
        AWS_DEFAULT_REGION = 'ap-southeast-2'
        TF_DIR = '02_EKS_terraform-manifests'
        ENV = 'dev'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Clean Terraform Cache') {
            steps {
                dir("${TF_DIR}") {
                    sh '''
                    rm -rf .terraform
                    rm -f .terraform.lock.hcl
                    '''
                }
            }
        }

        stage('Terraform Init') {
            steps {
                dir("${TF_DIR}") {
                    sh """
                    terraform init \
                      -reconfigure \
                      -upgrade \
                      -backend-config="bucket=jenkins-terraform-statefile-1807" \
                      -backend-config="key=${ENV}/eks/terraform.tfstate" \
                      -backend-config="region=${AWS_REGION}"
                    """
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Plan Destroy') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform plan -destroy -out=tfdestroy'
                }
            }
        }

        stage('Approval Before Destroy') {
            when {
                expression {
                    env.ENV == 'prod'
                }
            }
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    input message: "Approve destruction of ${ENV} environment?", ok: "Approve"
                }
            }
        }

        stage('Terraform Destroy') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform destroy -auto-approve'
                }
            }
        }

        stage('Verify Cleanup') {
            steps {
                sh '''
                echo "✅ Checking AWS resources after destroy..."
                aws eks list-clusters --region ${AWS_REGION}
                aws ec2 describe-instances --region ${AWS_REGION} --filters "Name=tag:Environment,Values=${ENV}"
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Terraform destroy completed successfully for ${ENV} environment."
        }
        failure {
            echo "❌ Terraform destroy failed."
        }
    }
}
