pipeline {
    agent any

    environment {
        AWS_REGION = 'ap-southeast-2'
        AWS_DEFAULT_REGION = 'ap-southeast-2'
        TF_DIR = '02_EKS_terraform-manifests'
        ENV = 'dev'   // change to 'prod' later or parameterize
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Clean Terraform Cache') {
            steps {
                dir("${TF_DIR}") {
                    sh '''
                    rm -rf .terraform
                    rm -f .terraform.lock.hcl
                    '''
                }
            }
        }

        stage('Terraform Format Check') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform fmt -recursive'
                    sh 'terraform fmt -check -recursive'
                }
            }
        }

        stage('Terraform Init') {
            steps {
                dir("${TF_DIR}") {
                    withEnv([
                        "AWS_REGION=${AWS_REGION}",
                        "AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION}"
                    ]) {
                        sh """
                        terraform init -reconfigure -upgrade \
                        -backend-config="bucket=jenkins-terraform-statefile-1807" \
                        -backend-config="key=${ENV}/eks/terraform.tfstate" \
                        -backend-config="region=${AWS_REGION}"
                        """
                    }
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform validate'
                }
            }
        }

        stage('Security Scan') {
            steps {
                dir("${TF_DIR}") {
                    sh 'checkov -d . || true'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir("${TF_DIR}") {
                    withEnv([
                        "AWS_REGION=${AWS_REGION}",
                        "AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION}"
                    ]) {
                        sh 'terraform plan -out=tfplan'
                    }
                }
            }
        }
        stage('Debug AWS') {
            steps {
                sh '''
                which aws
                aws --version
                '''
            }
        }
        

        stage('Configure Kubeconfig') {
            steps {
                withEnv([
                    "AWS_REGION=${AWS_REGION}",
                    "AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION}"
                ]) {
                    sh """
                    mkdir -p ~/.kube
                    /usr/bin/aws eks update-kubeconfig \
                      --region ${AWS_REGION} \
                      --name retail-dev-eksdemo1
                    """
                }
            }
        }

        // ✅ Approval only for PROD
        stage('Approval') {
            when {
                expression {
                    return env.ENV == 'prod'
                }
            }
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    input message: "Approve deployment to ${ENV}?", ok: "Approve"
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                dir("${TF_DIR}") {
                    withEnv([
                        "AWS_REGION=${AWS_REGION}",
                        "AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION}"
                    ]) {
                        sh 'terraform apply -auto-approve tfplan'
                    }
                }
            }
        }
    }

    post {
        success {
            echo "✅ Deployment to ${ENV} successful"
        }
        failure {
            echo "❌ Deployment failed"
        }
    }
}
