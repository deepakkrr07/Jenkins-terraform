pipeline {
    agent any

    environment {
        AWS_REGION   = 'ap-southeast-2'
        CLUSTER_NAME = 'retail-dev-eksdemo1'
        MANIFEST_DIR = 'karpenter_manifestyaml'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Configure Kubeconfig') {
            steps {
                sh '''
                mkdir -p ~/.kube
                aws eks update-kubeconfig \
                  --region ${AWS_REGION} \
                  --name ${CLUSTER_NAME}
                '''
            }
        }

        stage('Verify Cluster') {
            steps {
                sh 'kubectl get nodes'
            }
        }

        stage('Delete Karpenter Resources') {
            steps {
                dir("${MANIFEST_DIR}") {
                    sh '''
                    set -e
                    echo "Deleting Karpenter resources..."

                    kubectl delete -f nodepool.yaml --ignore-not-found
                    kubectl delete -f 01_ec2nodeclass.yaml --ignore-not-found

                    echo "✅ Karpenter manifests deleted successfully."
                    '''
                }
            }
        }

        stage('Verify Deletion') {
            steps {
                sh '''
                echo "========== Remaining EC2NodeClasses =========="
                kubectl get ec2nodeclass || true

                echo ""
                echo "========== Remaining NodePools =========="
                kubectl get nodepool || true
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Cleanup completed successfully."
        }
        failure {
            echo "❌ Cleanup failed."
        }
    }
}
