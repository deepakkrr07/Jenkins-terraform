pipeline {
    agent any

    environment {
        AWS_REGION = 'ap-southeast-2'
        TF_DIR = '02_RetailStore_AWS_Dataplane'
        ENV = 'dev'   // change to prod later or pass as parameter
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout Full Repo') {
            steps {
                checkout scm
            }
        }

        stage('Verify Tools') {
            steps {
                sh '''
                terraform version
                aws --version
                kubectl version --client
                '''
            }
        }

        stage('Configure Kubeconfig') {
            steps {
                sh '''
                mkdir -p ~/.kube
                aws eks update-kubeconfig \
                  --region ${AWS_REGION} \
                  --name retail-dev-eksdemo1
                '''
            }
        }

        stage('Terraform Init') {
            steps {
                dir("${TF_DIR}") {
                    sh """
                    terraform init -reconfigure \
                    -backend-config="bucket=jenkins-terraform-statefile-1807" \
                    -backend-config="key=\${ENV}/awsservices/terraform.tfstate" \
                    -backend-config="region=${AWS_REGION}"
                    """
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Plan Destroy') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform plan -destroy -out=tfdestroy'
                }
            }
        }

        stage('Approval Before Destroy') {
            when {
                expression {
                    return env.ENV == 'prod'
                }
            }
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    input message: "Approve destruction of ${ENV} environment?", ok: "Approve"
                }
            }
        }

        stage('Terraform Destroy') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform destroy -auto-approve'
                }
            }
        }

        stage('Verify Cleanup') {
            steps {
                sh '''
                echo "✅ Checking AWS resources after destroy..."
                aws eks list-clusters --region ${AWS_REGION}
                aws ec2 describe-instances --region ${AWS_REGION} --filters "Name=tag:Environment,Values=${ENV}"
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Terraform destroy completed successfully for ${ENV} environment."
        }
        failure {
            echo "❌ Terraform destroy failed."
        }
    }
}
