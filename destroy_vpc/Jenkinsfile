pipeline {
    agent any

    environment {
        AWS_REGION = 'ap-southeast-2'
        TF_DIR = '01_VPC_terraform-manifests'
        ENV = 'dev'   // change to prod later or pass as parameter
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Terraform Format Check') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform fmt -check -recursive'
                }
            }
        }

        stage('Terraform Init') {
            steps {
                dir("${TF_DIR}") {
                    sh """
                    terraform init -reconfigure \
                    -backend-config="bucket=jenkins-terraform-statefile-1807" \
                    -backend-config="key=\${ENV}/vpc/terraform.tfstate" \
                    -backend-config="region=${AWS_REGION}"
                    """
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Plan Destroy') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform plan -destroy -out=tfdestroy'
                }
            }
        }

        stage('Approval Before Destroy') {
            when {
                expression {
                    return env.ENV == 'prod'
                }
            }
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    input message: "Approve destruction of ${ENV} environment?", ok: "Approve"
                }
            }
        }

        stage('Terraform Destroy') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform destroy -auto-approve'
                }
            }
        }

        stage('Verify Cleanup') {
            steps {
                sh '''
                echo "✅ Checking AWS resources after destroy..."
                aws ec2 describe-vpcs --region ${AWS_REGION}
                aws ec2 describe-subnets --region ${AWS_REGION}
                aws ec2 describe-route-tables --region ${AWS_REGION}
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Terraform destroy completed successfully for ${ENV} environment."
        }
        failure {
            echo "❌ Terraform destroy failed."
        }
    }
}
