pipeline {
    agent any

    parameters {
        choice(
            name: 'APP_VERSION',
            choices: ['v1', 'v2'],
            description: 'Select Retail Store application version'
        )
        choice(
            name: 'ACTION',
            choices: ['deploy', 'cleanup'],
            description: 'Choose whether to deploy or delete resources'
        )
    }

    environment {
        AWS_REGION   = 'ap-southeast-2'
        CLUSTER_NAME = 'retail-dev-eksdemo1'
        NAMESPACE    = 'retailstore'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Set Helm Chart Path') {
            steps {
                script {
                    if (params.APP_VERSION == 'v1') {
                        env.HELM_DIR = "03_RetailStore_Helm_with_Data_Plane/01_retailstore_charts_updates/charts_v1.0.0"
                    } else {
                        env.HELM_DIR = "03_RetailStore_Helm_with_Data_Plane/01_retailstore_charts_updates/charts_v2.0.0"
                    }

                    echo "Selected Version : ${params.APP_VERSION}"
                    echo "Helm Directory   : ${env.HELM_DIR}"
                }
            }
        }

        stage('Configure Kubeconfig') {
            steps {
                sh '''
                mkdir -p ~/.kube
                aws eks update-kubeconfig \
                    --region ${AWS_REGION} \
                    --name ${CLUSTER_NAME}
                '''
            }
        }

        stage('Verify Cluster') {
            steps {
                sh 'kubectl get nodes'
            }
        }

        stage('Debug Workspace') {
            steps {
                sh '''
                echo "Current workspace: $(pwd)"
                ls -R 03_RetailStore_Helm_with_Data_Plane/kubernetes
                '''
            }
        }
       stage('Deploy Ingress') {
            steps {
                sh '''
                kubectl apply -f 03_RetailStore_Helm_with_Data_Plane/kubernetes/retail-ingress.yaml
                '''
            }
        }


       stage('Deploy or Cleanup') {
            steps {
                script {
                    if (params.ACTION == 'deploy') {
                        dir("${HELM_DIR}") {
                            sh '''
                            set -e
                            echo "Deploying Retail Store ${APP_VERSION}"
        
                            for chart in */ ; do
                                APP=$(basename "$chart")
                                echo "------------------------------------------"
                                echo "Deploying $APP"
                                echo "------------------------------------------"
        
                                helm upgrade --install "$APP" "$chart" \
                                    --namespace ${NAMESPACE} \
                                    --create-namespace \
                                    --wait
        
                                echo "$APP deployment completed"
                            done
                            '''
                        }
                    } else {
                        sh '''
                        set -e
                        echo "========== Deleting Helm Releases =========="
                        helm list -n ${NAMESPACE} -q | xargs -r -n1 helm uninstall -n ${NAMESPACE}
        
                        echo "========== Deleting Ingress =========="
                        kubectl delete -f 03_RetailStore_Helm_with_Data_Plane/kubernetes/retail-ingress.yaml --ignore-not-found
        
                        echo "========== Deleting Namespace =========="
                        kubectl delete namespace ${NAMESPACE} --ignore-not-found
                        '''
                    }
                }
            }
        }

 
  

        stage('Verify State') {
            steps {
                sh '''
                echo "========== Helm Releases =========="
                helm list -n ${NAMESPACE} || true

                echo ""
                echo "========== Pods =========="
                kubectl get pods -n ${NAMESPACE} || true

                echo ""
                echo "========== Services =========="
                kubectl get svc -n ${NAMESPACE} || true

                echo ""
                echo "========== Deployments =========="
                kubectl get deploy -n ${NAMESPACE} || true
                '''
            }
        }
    }

    post {
        success {
            script {
                if (params.ACTION == 'deploy') {
                    echo "Retail Store ${params.APP_VERSION} deployed successfully."
                } else {
                    echo "Retail Store ${params.APP_VERSION} resources cleaned up successfully."
                }
            }
        }
        failure {
            echo "Pipeline failed during ${params.ACTION}."
        }
    }
}
