pipeline {
    agent any

    environment {
        AWS_REGION   = 'ap-southeast-2'
        CLUSTER_NAME = 'retail-dev-eksdemo1'
        NAMESPACE    = 'retailstore'
        INGRESS_FILE = '03_RetailStore_Helm_with_Data_Plane/kubernetes/retail-ingress.yaml'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Configure Kubeconfig') {
            steps {
                sh '''
                mkdir -p ~/.kube
                aws eks update-kubeconfig \
                    --region ${AWS_REGION} \
                    --name ${CLUSTER_NAME}
                '''
            }
        }

        stage('Delete Ingress') {
            steps {
                sh '''
                echo "Deleting Ingress resource..."
                kubectl delete -f ${INGRESS_FILE} --ignore-not-found
                '''
            }
        }

        stage('Wait for ALB Cleanup') {
            steps {
                sh '''
                echo "Waiting for ALB controller to clean up..."
                sleep 60
                '''
            }
        }

        stage('Force Delete Orphaned ALB') {
            steps {
                sh '''
                echo "Checking for orphaned ALBs..."
                LB_ARN=$(aws elbv2 describe-load-balancers --region ${AWS_REGION} \
                    --query "LoadBalancers[?LoadBalancerName=='retail-store-http-ip-mode'].LoadBalancerArn" \
                    --output text)

                if [ -n "$LB_ARN" ]; then
                    echo "Deleting orphaned ALB: $LB_ARN"
                    aws elbv2 delete-load-balancer --load-balancer-arn $LB_ARN --region ${AWS_REGION}
                else
                    echo "No orphaned ALB found."
                fi
                '''
            }
        }

        stage('Verify Cleanup') {
            steps {
                sh '''
                echo "Verifying ALB deletion..."
                aws elbv2 describe-load-balancers --region ${AWS_REGION} \
                    --query "LoadBalancers[?LoadBalancerName=='retail-store-http-ip-mode']" \
                    --output table || true
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Ingress and ALB cleanup completed successfully."
        }
        failure {
            echo "❌ Cleanup failed — check ALB controller logs or AWS console."
        }
    }
}
